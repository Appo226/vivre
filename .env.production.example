# =============================================================================
# VIVRE — Variables d'environnement de production
# Copier ce fichier en .env.production sur le VPS et renseigner toutes les valeurs.
# Ne jamais committer .env.production dans Git.
# =============================================================================

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=vivre_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=vivre_prod

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 64
JWT_SECRET=CHANGE_ME_64_HEX_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_64_HEX_CHARS_DIFFERENT

# ─── URLs publiques ───────────────────────────────────────────────────────────
API_URL=https://api.vivre.bf
WEB_URL=https://vivre.bf

# ─── Docker images ────────────────────────────────────────────────────────────
GITHUB_REPOSITORY_OWNER=Appo226
IMAGE_TAG=latest

# ─── CinetPay (paiements Orange Money / Moov Money / Telecel Money) ───────────
CINETPAY_API_KEY=CHANGE_ME
CINETPAY_SITE_ID=CHANGE_ME

# ─── Twilio (SMS OTP) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ─── Anthropic (AI Assistant) ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ─── Firebase Admin (notifications push FCM) ──────────────────────────────────
# Encoder le fichier JSON du service account en base64 :
# base64 -i serviceAccountKey.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT_JSON=CHANGE_ME_BASE64_ENCODED_SERVICE_ACCOUNT_JSON

# ─── Next.js / Firebase Client (injectés au build, pas au runtime) ─────────────
# Ces variables sont des GitHub Actions secrets — pas besoin de les mettre ici.
# Elles sont passées via --build-arg dans le Dockerfile web.
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_VAPID_KEY=
