{
  "name": "vivre-platform",
  "version": "0.1.0",
  "private": true,
  "description": "VIVRE — Super-application pour le Burkina Faso. Voyager. Manger. Découvrir.",
  "author": "VIVRE Team <team@vivre.bf>",
  "license": "UNLICENSED",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @vivre/database run generate",
    "db:migrate": "pnpm --filter @vivre/database run migrate",
    "db:seed": "pnpm --filter @vivre/database run seed",
    "db:studio": "pnpm --filter @vivre/database run studio",
    "docker:up": "docker-compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f docker/docker-compose.yml down",
    "db:postgis": "docker cp docker/postgres/postgis-indexes.sql vivre-postgres:/tmp/postgis-indexes.sql && docker exec vivre-postgres psql -U vivre_user -d vivre_dev -f /tmp/postgis-indexes.sql"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.0"
  },
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
