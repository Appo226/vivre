{
  /**
   * apps/web — Application cliente principale VIVRE (Next.js 14 PWA)
   *
   * Point d'entrée pour les utilisateurs finaux : voyageurs, touristes, résidents.
   * Accessible sur vivre.bf et installable comme PWA sur smartphone Android/iOS.
   *
   * Technologies clés :
   * - Next.js 14 App Router (Server Components + Streaming)
   * - next-pwa : Service Worker pour le mode offline (services publics, SOTRACO)
   * - Tailwind CSS + design system @vivre/ui
   * - MapLibre GL (cartes open-source sans frais — important pour le budget)
   * - Zustand (state management léger — pas de Redux complexe)
   * - TanStack Query (server state, cache, pagination)
   * - Socket.io client (suivi en temps réel des courses et commandes)
   * - next-intl (i18n FR/EN)
   *
   * Port de développement : 3000
   */
  "name": "@vivre/web",
  "version": "0.1.0",
  "private": true,
  "description": "Application client VIVRE — Next.js 14 PWA",
  "scripts": {
    "build": "next build",
    "dev": "next dev --port 3000",
    "start": "next start --port 3000",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "clean": "rimraf .next"
  },
  "dependencies": {
    /* Next.js et React */
    "next": "14.2.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",

    /* PWA — Service Worker et offline support */
    "next-pwa": "^5.6.0",

    /* Design */
    "tailwindcss": "^3.4.0",
    "framer-motion": "^11.1.0",

    /* Cartes (open-source — pas de frais Google Maps) */
    "maplibre-gl": "^4.1.0",
    "react-map-gl": "^7.1.0",

    /* State management */
    "zustand": "^4.5.0",
    "@tanstack/react-query": "^5.35.0",

    /* Formulaires et validation */
    "react-hook-form": "^7.51.0",
    "zod": "^3.23.0",
    "@hookform/resolvers": "^3.3.0",

    /* UI Components */
    "lucide-react": "^0.367.0",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "embla-carousel-react": "^8.1.0",
    "react-otp-input": "^3.1.0",

    /* Temps réel */
    "socket.io-client": "^4.7.0",

    /* Internationalisation FR/EN */
    "next-intl": "^3.12.0",

    /* Packages internes */
    "@vivre/ui": "workspace:*",
    "@vivre/types": "workspace:*",
    "@vivre/utils": "workspace:*",
    "@vivre/config": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0",
    "@playwright/test": "^1.43.0"
  }
}
