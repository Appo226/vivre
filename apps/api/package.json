{
  "name": "@vivre/api",
  "version": "0.1.0",
  "private": true,
  "description": "API REST + WebSocket Fastify pour la plateforme VIVRE",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --env-file ../../.env.local src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.0.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/multipart": "^8.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "@fastify/swagger": "^8.14.0",
    "@google-cloud/storage": "^7.19.0",
    "@pinecone-database/pinecone": "^2.2.0",
    "@prisma/client": "^5.14.0",
    "@vivre/database": "workspace:*",
    "@vivre/types": "workspace:*",
    "@vivre/utils": "workspace:*",
    "bcryptjs": "^2.4.3",
    "dayjs": "^1.11.0",
    "fastify": "^4.27.0",
    "firebase-admin": "^12.1.0",
    "ioredis": "^5.3.0",
    "nanoid": "^5.0.0",
    "node-cron": "^3.0.3",
    "pino": "^8.21.0",
    "pino-pretty": "^11.0.0",
    "socket.io": "^4.7.0",
    "stripe": "^14.22.0",
    "twilio": "^5.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.12.0",
    "@types/node-cron": "^3.0.11",
    "@vivre/config": "workspace:*",
    "rimraf": "^5.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  }
}
