// =============================================================
// schema.prisma — Schéma Prisma complet pour la plateforme VIVRE
//
// Base de données : PostgreSQL 15+ avec extension PostGIS (géospatial)
// 34 tables organisées en 11 sections selon le DatabaseSchema_v1.3
//
// PostGIS est utilisé pour :
// - Tri des services publics par distance GPS (ST_Distance)
// - Zones de couverture des restaurants (ST_Within)
// - Affichage des chauffeurs disponibles dans un rayon (ST_DWithin)
//
// Note sur PostGIS dans Prisma :
// Prisma ne supporte pas nativement les types PostGIS (GEOGRAPHY, GEOMETRY).
// On stocke lat/lng comme Float et on utilise des Prisma.$queryRaw pour les
// requêtes géospatiales avancées. Les index GIST PostGIS sont créés dans init.sql.
//
// Conventions absolues :
// - Tous les PKs sont des UUIDs (sécurité + scalabilité)
// - Toutes les tables ont created_at, updated_at
// - Les soft-deletes utilisent deleted_at nullable
// - Les montants financiers sont en FCFA (entiers, pas de décimales)
// =============================================================

generator client {
  provider = "prisma-client-js"
  // Preview features : fullTextSearch pour la recherche de restaurants/hôtels
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================
// SECTION 01 — UTILISATEURS & AUTHENTIFICATION
// 3 tables : users, user_roles, otp_codes
// =============================================================

// Table principale des utilisateurs VIVRE.
// L'authentification est basée sur le numéro de téléphone (+226) + OTP SMS.
// Un utilisateur peut avoir plusieurs rôles (voir user_roles).
model User {
  id                 String   @id @default(uuid())
  // Numéro de téléphone au format E.164 (+226XXXXXXXX) — identifiant principal
  phone              String   @unique
  // Email optionnel — requis pour les fournisseurs et l'admin
  email              String?  @unique
  password_hash      String?  // Null = connexion uniquement par OTP
  first_name         String?
  last_name          String?
  avatar_url         String?  // URL S3 de la photo de profil
  preferred_language String   @default("fr") // "fr" ou "en"
  is_verified        Boolean  @default(false) // true après premier OTP validé
  is_active          Boolean  @default(true)  // false = compte bloqué par admin
  last_login_at      DateTime?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  deleted_at         DateTime? // Soft delete — ne jamais supprimer un user en dur

  // Relations
  roles                UserRole[]
  otp_codes            OtpCode[]
  transport_bookings   TransportBooking[]
  property_bookings    PropertyBooking[]
  orders               Order[]
  guide_bookings       GuideBooking[]
  ride_requests        RideRequest[]
  reviews              Review[]
  payments             Payment[]
  notifications        Notification[]
  device_tokens        DeviceToken[]
  service_corrections  ServiceCorrection[]
  // Relations fournisseur
  transport_company    TransportCompany?
  property             Property[]
  restaurant           Restaurant[]
  guide                Guide?
  driver               Driver?
  // Événements organisés (rôle organisateur)
  organized_events          Event[]           @relation("OrganizedEvents")
  event_bookings            EventBooking[]    @relation("EventBookingOwner")
  received_event_bookings   EventBooking[]    @relation("EventBookingTransfer")
  // Portefeuille VIVRE (crédits remboursements)
  wallet                    VivreWallet?

  @@map("users")
}

// Rôles d'un utilisateur — un user peut avoir plusieurs rôles simultanément.
// Les rôles supplier et driver nécessitent une approbation admin (is_approved).
model UserRole {
  id          String   @id @default(uuid())
  user_id     String
  // Enum inline Prisma : customer, supplier, driver, admin
  role        String   // customer | supplier | driver | admin
  is_approved Boolean  @default(false) // true = approuvé par admin
  approved_at DateTime?
  approved_by String?  // UUID de l'admin qui a approuvé
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user        User     @relation(fields: [user_id], references: [id])

  @@unique([user_id, role]) // Un seul rôle de chaque type par utilisateur
  @@index([user_id])
  @@map("user_roles")
}

// Codes OTP temporaires envoyés par SMS via Twilio.
// expires_at = created_at + 5 minutes (configurable via env).
// used_at non-null = code déjà consommé (ne peut pas être réutilisé).
model OtpCode {
  id         String   @id @default(uuid())
  phone      String   // +226XXXXXXXX
  code       String   @db.Char(6) // 6 chiffres
  purpose    String   // "login" | "verify" | "reset"
  expires_at DateTime
  used_at    DateTime? // null = pas encore utilisé
  created_at DateTime @default(now())

  // Relation optionnelle vers User (null si user non encore créé)
  user_id    String?
  user       User?    @relation(fields: [user_id], references: [id])

  @@index([phone, code, purpose]) // Lookup rapide lors de la vérification OTP
  @@map("otp_codes")
}

// =============================================================
// SECTION 02 — GÉOGRAPHIE
// 1 table : cities
// =============================================================

// Villes couvertes par VIVRE. 10 villes initiales au Burkina Faso.
// has_transport/has_food/has_drivers : modules activés par ville.
// L'admin peut activer/désactiver des modules par ville via ADM-004.
model City {
  id            String  @id @default(uuid())
  name          String  @unique // Nom français (ex: "Ouagadougou") — unique car chaque ville a un nom distinct
  name_en       String? // Nom anglais optionnel
  region        String  // Région administrative du Burkina
  country_code  String  @default("BFA") // ISO 3166-1 alpha-3
  latitude      Float
  longitude     Float
  population    Int?
  is_active     Boolean @default(true)
  // Modules activés pour cette ville
  has_transport Boolean @default(false)
  has_food      Boolean @default(false)
  has_drivers   Boolean @default(false)
  // Tarification intraurbaine — modifiable par l'admin sans redéploiement
  taxi_rate_per_km     Int   @default(250) // FCFA par km, taxi voiture
  zemidjan_rate_per_km Int   @default(150) // FCFA par km, moto-taxi
  min_fare             Int   @default(500) // FCFA minimum facturation
  night_rate_multiplier Float @default(1.0) // Multiplicateur nuit (ex: 1.2 = +20% après 22h)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Relations
  transport_companies TransportCompany[]
  routes_origin       Route[]            @relation("OriginCity")
  routes_destination  Route[]            @relation("DestinationCity")
  drivers             Driver[]
  properties          Property[]
  restaurants         Restaurant[]
  attractions         Attraction[]
  guides              Guide[]
  public_services     PublicService[]
  urban_lines         UrbanLine[]
  ride_requests       RideRequest[]
  events              Event[]
  pricing_rules       CityPricingRule[]

  @@index([country_code, is_active])
  @@map("cities")
}

// Règles tarifaires d'une ville — s'empilent sur les tarifs de base
// Exemple : +20% en janvier (FESPACO), +15% heure de pointe 17h-20h
model CityPricingRule {
  id      String @id @default(uuid())
  city_id String
  city    City   @relation(fields: [city_id], references: [id], onDelete: Cascade)

  label   String   // Nom lisible : "Saison des pluies", "FESPACO 2026", "Rush du soir"

  // Conditions temporelles — ET logique entre toutes les conditions définies.
  // Un tableau vide signifie "toujours" pour cette dimension.
  months      Int[]    // 1=jan … 12=déc.  Vide = tous les mois.
  weekdays    Int[]    // 0=dim, 1=lun … 6=sam.  Vide = tous les jours.
  hour_start  Int?     // 0–23. Null = pas de contrainte horaire.
  hour_end    Int?     // 0–23 inclus. Si hour_end < hour_start → chevauchement minuit.
  date_from   DateTime? // Début d'une fenêtre calendaire (optionnel)
  date_to     DateTime? // Fin d'une fenêtre calendaire  (optionnel, inclus)

  // Multiplicateurs appliqués au tarif de base de la ville
  // Plusieurs règles actives se multiplient entre elles, plafonnées à 2.0×
  taxi_multiplier     Float @default(1.0)
  zemidjan_multiplier Float @default(1.0)

  priority  Int     @default(0)    // Ordre d'affichage — n'affecte pas le calcul (compound)
  is_active Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([city_id, is_active])
  @@map("city_pricing_rules")
}

// =============================================================
// SECTION 03 — TRANSPORT INTERURBAIN
// 5 tables : transport_companies, routes, schedules, trips, transport_bookings
// =============================================================

// Compagnie de transport interurbain (TSR, STMB, Rakieta, Sonef, TCV, Rimbo, etc.)
// owner_id = compte utilisateur du gestionnaire de la compagnie.
model TransportCompany {
  id             String   @id @default(uuid())
  owner_id       String   @unique // Un owner = une compagnie (relation 1-1)
  name           String
  logo_url       String?
  phone          String
  email          String?
  address        String   // Adresse de la gare routière
  city_id        String
  license_number String?
  is_approved    Boolean  @default(false) // Admin doit approuver
  is_active      Boolean  @default(true)
  rating_avg     Float    @default(0)
  total_reviews  Int      @default(0)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  deleted_at     DateTime?

  owner          User     @relation(fields: [owner_id], references: [id])
  city           City     @relation(fields: [city_id], references: [id])
  routes         Route[]

  @@index([city_id, is_active, is_approved])
  @@map("transport_companies")
}

// Ligne de bus interurbain (itinéraire fixe entre deux villes).
// distance_km et duration_minutes sont calculés une fois à la création.
model Route {
  id                    String  @id @default(uuid())
  company_id            String
  origin_city_id        String
  destination_city_id   String
  distance_km           Int
  duration_minutes      Int
  bus_type              String  // "standard" | "confort" | "vip" | "minibus"
  total_seats           Int
  // Politique d'annulation billet
  cancel_policy         String  @default("moderate") // "flexible"|"moderate"|"strict"|"non_refundable"
  cancel_full_refund_h  Int     @default(24)  // Heures avant départ → remboursement intégral
  cancel_partial_h      Int     @default(2)   // Heures avant départ → remboursement partiel
  cancel_partial_pct    Int     @default(50)  // % remboursé dans la fenêtre partielle
  is_active             Boolean @default(true)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt
  deleted_at            DateTime?

  company               TransportCompany @relation(fields: [company_id], references: [id])
  origin_city           City             @relation("OriginCity", fields: [origin_city_id], references: [id])
  destination_city      City             @relation("DestinationCity", fields: [destination_city_id], references: [id])
  schedules             Schedule[]
  trips                 Trip[]

  @@index([company_id, origin_city_id, destination_city_id])
  @@index([origin_city_id, destination_city_id, is_active])
  @@map("routes")
}

// Planning récurrent d'une ligne (jours et horaires de départ).
// days_of_week : tableau d'entiers 1-7 (1=Lundi...7=Dimanche).
model Schedule {
  id             String  @id @default(uuid())
  route_id       String
  departure_time String  // "HH:MM"
  arrival_time   String  // "HH:MM"
  // JSON array d'entiers ex: [1,3,5] pour lundi/mercredi/vendredi
  days_of_week   Int[]
  base_price     Int     // FCFA — tarif adulte
  child_price    Int     // FCFA — tarif enfant (~30% moins cher)
  student_price  Int     // FCFA — tarif étudiant
  is_active      Boolean @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  route          Route   @relation(fields: [route_id], references: [id])
  trips          Trip[]

  @@index([route_id, is_active])
  @@map("schedules")
}

// Voyage concret — instance d'un Schedule à une date précise.
// available_seats est décrémenté automatiquement à chaque réservation confirmée
// via un trigger PostgreSQL (défini dans init.sql).
model Trip {
  id                String   @id @default(uuid())
  schedule_id       String
  route_id          String
  departure_datetime DateTime // TIMESTAMPTZ — heure de départ réelle
  arrival_datetime   DateTime
  available_seats   Int
  status            String   @default("scheduled") // "scheduled"|"boarding"|"departed"|"completed"|"cancelled"
  override_price    Int?     // Si défini, remplace le base_price du Schedule
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  schedule          Schedule @relation(fields: [schedule_id], references: [id])
  route             Route    @relation(fields: [route_id], references: [id])
  bookings          TransportBooking[]

  @@index([route_id, departure_datetime, status])
  @@index([departure_datetime, status]) // Recherche par date
  @@map("trips")
}

// Réservation de bus effectuée par un client.
// seat_numbers : tableau de strings (ex: ["12A", "12B"])
// qr_code : données JSON encodées pour le billet numérique
// Les sièges sont réservés 10 minutes en attente de paiement, puis libérés si non payés.
model TransportBooking {
  id                   String   @id @default(uuid())
  user_id              String
  trip_id              String
  passenger_count      Int
  seat_numbers         String[] // VARCHAR[]
  passenger_type       String   // "adult" | "child" | "student"
  total_amount         Int      // FCFA
  status               String   @default("pending_payment") // pending_payment|pending|confirmed|cancelled|completed
  payment_id           String?
  qr_code              String   // Données QR en base64 ou JSON
  cancelled_at         DateTime?
  cancellation_reason  String?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  user                 User     @relation(fields: [user_id], references: [id])
  trip                 Trip     @relation(fields: [trip_id], references: [id])
  payment              Payment? @relation(fields: [payment_id], references: [id])

  @@index([trip_id, status])
  @@index([user_id, status])
  @@map("transport_bookings")
}

// =============================================================
// SECTION 04 — TRANSPORT INTRAURBAIN
// 4 tables : drivers, ride_requests, urban_lines, urban_stops
// =============================================================

// Chauffeur intraurbain (taxi ou zémidjan) inscrit sur VIVRE.
// current_lat/current_lng = position GPS mise à jour toutes les 3s via WS.
// can_deliver_food = true → ce chauffeur reçoit aussi des demandes de livraison food.
model Driver {
  id               String   @id @default(uuid())
  user_id          String   @unique // Un user = un profil chauffeur max
  city_id          String
  driver_type      String   // "taxi" | "zemidjan" | "both"
  vehicle_type     String?  // Ex: "Moto Honda CG 125"
  vehicle_plate    String?
  license_number   String?
  is_available     Boolean  @default(false) // Toggle par le chauffeur
  current_lat      Float?
  current_lng      Float?
  last_location_at DateTime?
  can_deliver_food Boolean  @default(false)
  base_rate_fcfa   Int      @default(200) // Tarif de base FCFA/km
  rating_avg       Float    @default(0)
  is_approved        Boolean  @default(false)
  // application_status: "pending" | "approved" | "rejected"
  // pending = candidature soumise en attente de vérification admin
  // approved = dossier validé, le chauffeur peut livrer
  // rejected = dossier refusé (voir rejection_reason)
  application_status String   @default("pending")
  rejection_reason   String?  @db.Text // Raison de refus communiquée au candidat
  // documents : JSON { id_card_url, license_url, vehicle_reg_url, selfie_url }
  documents          Json?
  payout_phone       String?  // Numéro mobile money par défaut pour les versements
  payout_method      String?  // "orange_money" | "moov" | "telecel_money"
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  user             User     @relation(fields: [user_id], references: [id])
  city             City     @relation(fields: [city_id], references: [id])
  ride_requests    RideRequest[]
  food_deliveries  Order[]
  payouts          DriverPayout[]

  // Index géospatial — utilisé pour trouver les chauffeurs proches
  // L'index GIST PostGIS est créé dans init.sql car Prisma ne le supporte pas nativement
  @@index([city_id, is_available, driver_type])
  @@index([application_status])
  @@map("drivers")
}

// Versement automatique des gains d'un livreur.
// Les gains sont calculés depuis les Orders livrées (80% du delivery_fee).
// Le versement est déclenché automatiquement via le PayoutProviderRegistry —
// aucune intervention admin requise en conditions normales.
// Commission VIVRE : 20% du delivery_fee de chaque livraison.
model DriverPayout {
  id                      String   @id @default(uuid())
  driver_id               String
  amount_fcfa             Int      // Montant net (après commission VIVRE de 20%)
  deliveries_count        Int      // Nombre de livraisons couvertes
  period_from             DateTime // Début de la période couverte
  period_to               DateTime // Fin de la période couverte
  payment_method          String   // "orange_money" | "moov" | "telecel_money"
  phone_number            String   // Numéro mobile money du livreur
  status                  String   @default("processing")
  // "processing"  : virement initié, en attente de confirmation réseau
  // "paid"         : confirmé — livreur a bien reçu l'argent
  // "failed"       : échec du virement (voir failure_reason)
  provider_transaction_id String?  // ID de transaction côté opérateur (CinetPay Transfer)
  failure_reason          String?  // Message d'erreur si status = "failed"
  admin_note              String?  // Note admin visible en interne uniquement
  processed_at            DateTime?
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  driver                  Driver   @relation(fields: [driver_id], references: [id])

  @@index([driver_id, status])
  @@index([status, created_at])
  @@map("driver_payouts")
}

// Demande de course créée par un client.
// driver_id = null jusqu'à ce qu'un chauffeur accepte dans les 30s.
model RideRequest {
  id              String   @id @default(uuid())
  user_id         String
  driver_id       String?  // Null = en recherche de chauffeur
  city_id         String
  pickup_lat      Float
  pickup_lng      Float
  pickup_address  String?
  dropoff_lat     Float
  dropoff_lng     Float
  dropoff_address String?
  ride_type       String   // "taxi" | "zemidjan"
  estimated_price Int      // FCFA — calculé à la création
  final_price     Int?     // FCFA — défini à la fin de la course
  status          String   @default("searching")
  payment_method  String   @default("cash")
  payment_id      String?
  requested_at    DateTime @default(now())
  accepted_at     DateTime?
  completed_at    DateTime?
  cancelled_at    DateTime?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  user            User     @relation(fields: [user_id], references: [id])
  driver          Driver?  @relation(fields: [driver_id], references: [id])
  city            City     @relation(fields: [city_id], references: [id])

  @@index([driver_id, status])
  @@index([user_id, status])
  @@index([status, city_id]) // Pour diffuser aux chauffeurs disponibles dans une ville
  @@map("ride_requests")
}

// Ligne de bus urbain (SOTRACO, etc.) — données statiques disponibles offline.
model UrbanLine {
  id                String  @id @default(uuid())
  city_id           String
  operator_name     String  // Ex: "SOTRACO"
  line_number       String  // Ex: "L01"
  line_name         String  // Ex: "Ouaga 2000 — Dassasgho"
  color_hex         String  // Couleur sur la carte
  fare_fcfa         Int     // Tarif unique sur la ligne
  frequency_minutes Int     // Fréquence de passage en minutes
  is_active         Boolean @default(true)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  city              City    @relation(fields: [city_id], references: [id])
  stops             UrbanStop[]

  @@index([city_id, is_active])
  @@map("urban_lines")
}

// Arrêt de bus urbain sur une ligne SOTRACO.
// sequence_order définit l'ordre des arrêts (pour afficher la liste ordonnée).
model UrbanStop {
  id             String @id @default(uuid())
  line_id        String
  name           String
  sequence_order Int
  latitude       Float
  longitude      Float

  line           UrbanLine @relation(fields: [line_id], references: [id])

  @@index([line_id, sequence_order])
  @@map("urban_stops")
}

// =============================================================
// SECTION 05 — HÉBERGEMENT
// 3 tables : properties, room_types, property_bookings
// =============================================================

// Propriété hébergeant des clients (hôtel, auberge, campement, location, hostel).
// amenities : tableau de strings (ex: ["wifi", "piscine", "parking", "climatisation"])
// check_in_time / check_out_time : "HH:MM"
model Property {
  id                   String  @id @default(uuid())
  owner_id             String
  city_id              String
  name                 String
  property_type        String  // "hotel" | "auberge" | "campement" | "private" | "hostel"
  description          String? @db.Text
  address              String
  latitude             Float
  longitude            Float
  phone                String
  email                String?
  star_rating          Int?    // 1-5 étoiles (null si non classé)
  amenities            String[] // Tableau d'équipements
  check_in_time        String  @default("14:00")
  check_out_time       String  @default("12:00")
  cancellation_policy  String? @db.Text // Texte libre affiché à l'utilisateur
  // Politique structurée — utilisée par le moteur de remboursement
  cancel_policy        String  @default("strict") // "flexible"|"moderate"|"strict"|"non_refundable"
  cancel_full_refund_h Int?    // Heures avant check-in → remboursement intégral (ex: 72)
  cancel_partial_h     Int?    // Heures avant check-in → remboursement partiel (ex: 24)
  cancel_partial_pct   Int?    // Pourcentage remboursé dans la fenêtre partielle (0–100)
  is_approved          Boolean @default(false)
  is_active            Boolean @default(true)
  rating_avg           Float   @default(0)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  deleted_at           DateTime?

  owner                User    @relation(fields: [owner_id], references: [id])
  city                 City    @relation(fields: [city_id], references: [id])
  room_types           RoomType[]
  bookings             PropertyBooking[]

  @@index([city_id, property_type, is_active, is_approved])
  @@index([latitude, longitude]) // Pour la recherche géographique côté client
  @@map("properties")
}

// Type de chambre dans une propriété.
// quantity = nombre de chambres de ce type disponibles au total.
model RoomType {
  id            String  @id @default(uuid())
  property_id   String
  name          String  // Ex: "Chambre Standard", "Suite Junior"
  description   String? @db.Text
  max_occupancy Int
  bed_type      String  // "single" | "double" | "twin" | "king"
  price_per_night Int   // FCFA
  quantity      Int     // Nombre de chambres de ce type
  amenities     String[]
  is_active     Boolean @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  property      Property @relation(fields: [property_id], references: [id])
  bookings      PropertyBooking[]

  @@index([property_id, is_active])
  @@map("room_types")
}

// Réservation d'hébergement.
// nights_count est calculé à la création : diff(check_out, check_in) en jours.
model PropertyBooking {
  id               String   @id @default(uuid())
  user_id          String
  property_id      String
  room_type_id     String
  check_in_date    String   // "YYYY-MM-DD"
  check_out_date   String
  nights_count     Int
  guests_count     Int
  total_amount     Int      // FCFA
  special_requests String?
  status               String   @default("pending_payment") // pending_payment|pending|confirmed|cancelled|completed
  payment_id           String?
  cancelled_at         DateTime?
  cancellation_reason  String?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  user             User     @relation(fields: [user_id], references: [id])
  property         Property @relation(fields: [property_id], references: [id])
  room_type        RoomType @relation(fields: [room_type_id], references: [id])
  payment          Payment? @relation(fields: [payment_id], references: [id])

  @@index([property_id, status, check_in_date])
  @@index([user_id, status])
  @@index([room_type_id, check_in_date, check_out_date]) // Vérification disponibilité
  @@map("property_bookings")
}

// =============================================================
// SECTION 06 — FOOD DELIVERY
// 5 tables : restaurants, menu_categories, menu_items, orders, order_items
// =============================================================

// Restaurant ou établissement de restauration.
// opening_hours : JSON { "mon": "08:00-22:00", "sun": "closed" }
// is_open_now : calculé côté API en temps réel (non stocké)
model Restaurant {
  id                   String  @id @default(uuid())
  owner_id             String
  city_id              String
  name                 String
  restaurant_type      String  // "restaurant" | "maquis" | "fastfood" | "bakery" | "street_food"
  description          String? @db.Text
  address              String
  latitude             Float
  longitude            Float
  phone                String
  opening_hours        Json    // { "mon": "08:00-22:00", ... }
  delivery_radius_km   Float   @default(5)
  min_order_fcfa       Int     @default(0)
  avg_prep_minutes     Int     @default(30)
  offers_delivery      Boolean @default(true)
  offers_pickup        Boolean @default(true)
  is_approved          Boolean @default(false)
  is_active            Boolean @default(true)
  is_open_now          Boolean @default(false) // Mis à jour par un CRON toutes les 15 min
  rating_avg           Float   @default(0)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  deleted_at           DateTime?

  owner                User    @relation(fields: [owner_id], references: [id])
  city                 City    @relation(fields: [city_id], references: [id])
  menu_categories      MenuCategory[]
  menu_items           MenuItem[]
  orders               Order[]

  @@index([city_id, is_active, is_approved, is_open_now])
  @@index([latitude, longitude])
  @@map("restaurants")
}

// Catégorie de menu (Entrées, Plats, Grillades, Boissons, Desserts, etc.)
model MenuCategory {
  id            String  @id @default(uuid())
  restaurant_id String
  name          String
  sort_order    Int     @default(0)
  is_active     Boolean @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  restaurant    Restaurant @relation(fields: [restaurant_id], references: [id])
  items         MenuItem[]

  @@index([restaurant_id, is_active, sort_order])
  @@map("menu_categories")
}

// Plat ou article du menu.
// is_featured = true → affiché dans la section "Nos spécialités" du restaurant.
model MenuItem {
  id            String  @id @default(uuid())
  restaurant_id String
  category_id   String
  name          String
  description   String? @db.Text
  price         Int     // FCFA
  image_url     String?
  is_available  Boolean @default(true)
  is_featured   Boolean @default(false)
  prep_minutes  Int?
  sort_order    Int     @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  deleted_at    DateTime?

  restaurant    Restaurant   @relation(fields: [restaurant_id], references: [id])
  category      MenuCategory @relation(fields: [category_id], references: [id])
  order_items   OrderItem[]

  @@index([restaurant_id, category_id, is_available])
  @@map("menu_items")
}

// Commande food delivery ou click & collect.
// driver_id = null jusqu'à assignation d'un zémidjan.
model Order {
  id                    String   @id @default(uuid())
  user_id               String
  restaurant_id         String
  driver_id             String?  // Zémidjan assigné — null si pickup ou en attente
  order_type            String   // "delivery" | "pickup"
  delivery_address      String?  // Null si pickup
  delivery_lat          Float?
  delivery_lng          Float?
  subtotal              Int      // FCFA — total articles sans livraison
  delivery_fee          Int      @default(0) // FCFA — 0 si pickup
  total_amount          Int      // FCFA — subtotal + delivery_fee - promo
  status                String   @default("pending_payment") // pending_payment|pending|confirmed|preparing|ready|picked_up|delivered|cancelled
  payment_method        String   @default("orange_money")   // orange_money|moov|telecel_money
  payment_id            String?
  special_instructions  String?
  estimated_delivery_at DateTime?
  delivered_at          DateTime?
  cancelled_at          DateTime?
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  user                  User       @relation(fields: [user_id], references: [id])
  restaurant            Restaurant @relation(fields: [restaurant_id], references: [id])
  driver                Driver?    @relation(fields: [driver_id], references: [id])
  items                 OrderItem[]
  payment               Payment?   @relation(fields: [payment_id], references: [id])

  @@index([restaurant_id, status, created_at])
  @@index([driver_id, status])
  @@index([user_id, created_at])
  @@map("orders")
}

// Article d'une commande — snapshot du MenuItem au moment de la commande.
// On copie le prix pour que les modifications futures ne touchent pas les commandes passées.
model OrderItem {
  id           String @id @default(uuid())
  order_id     String
  menu_item_id String
  quantity     Int
  unit_price   Int    // FCFA — copié du MenuItem au moment de la commande
  subtotal     Int    // unit_price × quantity
  notes        String? // Instructions spécifiques pour ce plat

  order        Order    @relation(fields: [order_id], references: [id])
  menu_item    MenuItem @relation(fields: [menu_item_id], references: [id])

  @@index([order_id])
  @@map("order_items")
}

// =============================================================
// SECTION 07 — TOURISME & GUIDES
// 3 tables : attractions, guides, guide_bookings
// =============================================================

// Site ou attraction touristique au Burkina Faso.
// city_id est nullable pour les parcs nationaux qui couvrent plusieurs villes.
// description et description_en permettent le contenu bilingue.
model Attraction {
  id                    String  @id @default(uuid())
  city_id               String? // Null pour les sites régionaux/nationaux
  name                  String
  name_en               String?
  category              String  // "nature" | "culture" | "heritage" | "event" | "urban"
  description           String  @db.Text
  description_en        String? @db.Text
  address               String?
  latitude              Float
  longitude             Float
  entry_fee_fcfa        Int     @default(0) // 0 = entrée gratuite
  entry_fee_tourist     Int?    // Prix pour non-résidents (si différent)
  opening_hours         Json?   // { "mon": "08:00-17:00", ... } ou null si continu
  visit_duration_hours  Float?  // Durée recommandée de visite
  best_season           String? // Ex: "Novembre à Mars"
  is_unesco             Boolean @default(false) // Badge UNESCO si true
  is_featured           Boolean @default(false) // "À ne pas manquer"
  is_active             Boolean @default(true)
  rating_avg            Float   @default(0)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  city                  City?   @relation(fields: [city_id], references: [id])
  // Les réservations de guide référencent les attractions via attraction_ids (UUID array)
  // pas de relation Prisma directe — lookup via prisma.$queryRaw WHERE id = ANY(attraction_ids)

  @@index([city_id, category, is_active])
  @@index([is_featured, is_active])
  @@map("attractions")
}

// Guide touristique certifié sur la plateforme VIVRE.
// is_ontb_certified = true → certifié par l'Office National du Tourisme du Burkina.
// zones_covered : IDs de villes que le guide peut couvrir (UUID array).
// languages : codes ISO 639-1 (["fr", "en", "de"]).
model Guide {
  id                   String  @id @default(uuid())
  user_id              String  @unique
  city_id              String  // Ville principale du guide
  bio                  String  @db.Text
  languages            String[] // ["fr", "en", "dioula", "mooré"]
  specialties          String[] // ["culture", "nature", "gastronomie"]
  zones_covered        String[] // UUIDs de villes couvertes
  experience_years     Int?
  daily_rate_fcfa      Int
  half_day_rate_fcfa   Int?
  is_ontb_certified    Boolean @default(false)
  certification_number String?
  is_approved          Boolean @default(false)
  is_active            Boolean @default(true)
  rating_avg           Float   @default(0)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  deleted_at           DateTime?

  user                 User    @relation(fields: [user_id], references: [id])
  city                 City    @relation(fields: [city_id], references: [id])
  bookings             GuideBooking[]

  @@index([city_id, is_active, is_approved])
  @@index([is_ontb_certified, is_active])
  @@map("guides")
}

// Réservation d'un guide touristique.
// attraction_ids : UUIDs des sites à visiter (stockés en array).
model GuideBooking {
  id                String   @id @default(uuid())
  user_id           String
  guide_id          String
  booking_date      String   // "YYYY-MM-DD"
  booking_type      String   // "full_day" | "half_day" | "custom"
  duration_hours    Float?   // Requis si booking_type = "custom"
  group_size        Int
  attraction_ids    String[] // UUIDs des Attraction
  custom_itinerary  String?  @db.Text
  total_amount      Int      // FCFA
  status            String   @default("pending")
  payment_id        String?
  special_requests  String?
  cancelled_at      DateTime?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  user              User     @relation(fields: [user_id], references: [id])
  guide             Guide    @relation(fields: [guide_id], references: [id])
  payment           Payment? @relation(fields: [payment_id], references: [id])
  // attraction_ids String[] contient les UUIDs des attractions visitées.
  // Pas de relation Prisma : lookup via prisma.$queryRaw("SELECT * FROM attractions WHERE id = ANY($1)", attraction_ids)

  @@index([guide_id, status, booking_date])
  @@index([user_id, status])
  @@map("guide_bookings")
}

// =============================================================
// SECTION 08 — PAIEMENTS
// 2 tables : payments, refunds
// =============================================================

// Transaction de paiement — point central de toute transaction financière VIVRE.
// platform_fee = 12% de amount (commission VIVRE)
// supplier_amount = 88% de amount (versé au fournisseur)
model Payment {
  id             String   @id @default(uuid())
  user_id        String
  amount         Int      // FCFA
  currency       String   @default("XOF")
  payment_method String   // "orange_money" | "moov" | "telecel_money" — set from CinetPay webhook
  provider_ref   String?  // CinetPay payment_token — stocké à l'initiation
  status         String   @default("pending")   // pending|completed|failed|cancelled
  booking_type   String   // "transport" | "property" | "food" | "event"
  booking_id     String   // UUID de la réservation (polymorphique)
  platform_fee   Int      // FCFA — commission 12%
  supplier_amount Int     // FCFA — 88% reversé au fournisseur
  paid_at        DateTime?
  failed_at      DateTime?
  failure_reason String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  user           User     @relation(fields: [user_id], references: [id])
  refunds        Refund[]
  // Relations inverses depuis les tables de réservation
  transport_bookings  TransportBooking[]
  property_bookings   PropertyBooking[]
  orders              Order[]
  guide_bookings      GuideBooking[]
  event_bookings      EventBooking[]

  @@index([user_id, status])
  @@index([booking_type, booking_id])
  @@index([status, payment_method])
  @@map("payments")
}

// Remboursement associé à un paiement.
model Refund {
  id             String   @id @default(uuid())
  payment_id     String
  amount         Int      // FCFA — peut être partiel
  reason         String
  status         String   @default("pending") // "pending"|"completed"|"rejected"
  // Méthode choisie par l'utilisateur
  refund_method  String   @default("vivre_credit") // "vivre_credit" | "mobile_money"
  // Traçabilité de la réservation source
  booking_type   String?  // "transport" | "property" | "food" | "event"
  booking_id     String?  // UUID de la réservation concernée
  processed_by   String?  // UUID de l'admin
  processed_at   DateTime?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  payment        Payment  @relation(fields: [payment_id], references: [id])

  @@index([payment_id, status])
  @@index([status, refund_method]) // Pour le tableau de bord admin
  @@map("refunds")
}

// =============================================================
// SECTION 09 — REVIEWS (polymorphique)
// 1 table : reviews
// =============================================================

// Évaluation polymorphique — une seule table pour toutes les entités.
// entity_type + entity_id = référence vers n'importe quelle entité.
// is_verified = true uniquement si booking_ref_id est valide (avis vérifié).
// Le trigger PostgreSQL met à jour rating_avg sur l'entité parente après INSERT/UPDATE.
model Review {
  id             String  @id @default(uuid())
  user_id        String
  entity_type    String  // "transport_company" | "property" | "restaurant" | "guide" | "driver" | "attraction"
  entity_id      String  // UUID de l'entité concernée
  booking_ref_id String? // UUID de la réservation — si présent = avis vérifié
  rating         Int     // 1-5
  title          String?
  comment        String? @db.Text
  is_verified    Boolean @default(false) // true = client a utilisé le service
  is_visible     Boolean @default(true)  // false = masqué par admin
  response       String? @db.Text // Réponse du fournisseur à l'avis
  response_at    DateTime?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  user           User    @relation(fields: [user_id], references: [id])

  @@index([entity_type, entity_id, is_visible]) // Récupérer les avis d'une entité
  @@index([user_id])
  @@map("reviews")
}

// =============================================================
// SECTION 10 — MÉDIAS & NOTIFICATIONS
// 3 tables : media, notifications, promo_codes
// =============================================================

// Fichier média (photo ou vidéo) associé à une entité.
// entity_type + entity_id = référence polymorphique.
// Les fichiers sont stockés sur AWS S3, distribués via CloudFront.
// Modèle polymorphique — entity_type + entity_id référencent n'importe quelle entité.
// On n'utilise pas de relations Prisma typées ici car le polymorphisme Prisma
// nécessiterait une FK spécifique par type, ce qui n'est pas adapté à un modèle générique.
// Les lookups se font par requêtes WHERE entity_type = '...' AND entity_id = '...'.
model Media {
  id           String  @id @default(uuid())
  entity_type  String  // "property" | "restaurant" | "guide" | "attraction" | "user"
  entity_id    String  // UUID de l'entité (sans FK Prisma — polymorphique)
  url          String  // URL S3/CloudFront complète
  media_type   String  // "image" | "video"
  is_primary   Boolean @default(false) // Une seule photo primaire par entité
  sort_order   Int     @default(0)
  uploaded_by  String  // UUID de l'utilisateur qui a uploadé

  @@index([entity_type, entity_id, is_primary])
  @@map("media")
}

// Notification envoyée à un utilisateur.
// data : JSON avec les données contextuelles (ex: booking_id pour rediriger)
model Notification {
  id        String   @id @default(uuid())
  user_id   String
  type      String   // "booking_confirmed" | "order_ready" | "driver_arrived" | etc.
  title     String
  body      String
  data      Json?    // { booking_id: "...", screen: "TI_006" }
  channel   String   // "push" | "sms" | "whatsapp" | "email"
  is_read   Boolean  @default(false)
  sent_at   DateTime @default(now())
  read_at   DateTime?
  created_at DateTime @default(now())

  user      User     @relation(fields: [user_id], references: [id])

  @@index([user_id, is_read, sent_at])
  @@map("notifications")
}

// Token FCM (Firebase Cloud Messaging) pour les notifications push.
// Un utilisateur peut avoir plusieurs appareils simultanément (web + mobile).
// Le token est mis à jour à chaque connexion — FCM peut en changer.
model DeviceToken {
  id         String   @id @default(uuid())
  user_id    String
  token      String   @unique  // Token FCM — unique par appareil
  platform   String            // "web" | "android" | "ios"
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("device_tokens")
}

// Code promotionnel — peut cibler un module spécifique ou tous les modules.
model PromoCode {
  id                  String   @id @default(uuid())
  code                String   @unique
  discount_type       String   // "percent" | "fixed_fcfa"
  discount_value      Int      // % ou FCFA selon discount_type
  min_order_fcfa      Int?     // Commande minimum pour utiliser le code
  max_uses            Int?     // Null = usage illimité
  uses_count          Int      @default(0)
  max_uses_per_user   Int      @default(1)
  applies_to          String   @default("all") // "all" | "transport" | "food" | etc.
  supplier_id         String?  // Si défini → promo spécifique à un fournisseur
  valid_from          DateTime
  valid_until         DateTime
  is_active           Boolean  @default(true)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@index([code, is_active])
  @@index([valid_from, valid_until, is_active])
  @@map("promo_codes")
}

// =============================================================
// SECTION 11 — SERVICES PUBLICS & URGENCES
// 4 tables : public_service_categories, public_services, emergency_numbers, service_corrections
// =============================================================

// Catégorie de service public (Hôpital, Pharmacie, Police, etc.)
// is_emergency = true → mis en rouge en haut de l'écran SP-001.
model PublicServiceCategory {
  id          String  @id @default(uuid())
  slug        String  @unique // "hospital" | "pharmacy" | "police" | etc.
  name_fr     String
  name_en     String
  icon        String  // Nom d'icône Lucide React
  color_hex   String
  is_emergency Boolean @default(false)
  sort_order  Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  services    PublicService[]

  @@map("public_service_categories")
}

// Service public individuel (hôpital, pharmacie, commissariat...).
// latitude et longitude sont NOT NULL — requis pour le tri géospatial PostGIS.
// is_on_duty : calculé par CRON chaque nuit (pharmacies de garde uniquement).
model PublicService {
  id               String   @id @default(uuid())
  category_id      String
  city_id          String
  name             String
  name_en          String?
  address          String
  latitude         Float    // NOT NULL — coordonnées GPS requises
  longitude        Float
  phone_primary    String?
  phone_secondary  String?
  phone_emergency  String?
  opening_hours    Json?    // { "mon": "08:00-17:00", "sun": "closed" }
  is_24h           Boolean  @default(false)
  is_open_now      Boolean  @default(false) // Calculé en temps réel
  is_on_duty       Boolean  @default(false) // Spécifique aux pharmacies de garde
  on_duty_until    DateTime? // Fin de la permanence
  description      String?  @db.Text
  description_en   String?  @db.Text
  website          String?
  data_source      String   @default("manual") // "manual" | "osm" | "crowdsourced"
  last_verified_at DateTime?
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  category         PublicServiceCategory @relation(fields: [category_id], references: [id])
  city             City                  @relation(fields: [city_id], references: [id])
  corrections      ServiceCorrection[]

  // Index pour les requêtes les plus fréquentes
  @@index([city_id, category_id, is_active])
  @@index([is_on_duty, category_id]) // Lookup rapide pharmacies de garde
  // Index géospatial GIST PostGIS créé dans init.sql (non supporté par Prisma nativement)
  @@map("public_services")
}

// Numéros d'urgence nationaux — données statiques, disponibles offline.
model EmergencyNumber {
  id               String  @id @default(uuid())
  country_code     String  @default("BFA")
  service_name     String  @unique // Ex: "SAMU" — unique car un seul service par nom
  service_name_en  String  // Ex: "Emergency Medical Services"
  number           String  // Ex: "15" ou "+226 25 33 40 40"
  icon             String  // Nom d'icône Lucide React
  color_hex        String  @default("#C8102E") // Rouge urgence par défaut
  sort_order       Int     @default(0)
  is_active        Boolean @default(true)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@index([country_code, is_active, sort_order])
  @@map("emergency_numbers")
}

// Signalement d'erreur crowdsourcé sur un service public.
// user_id est nullable — on accepte les signalements anonymes pour maximiser la participation.
model ServiceCorrection {
  id               String   @id @default(uuid())
  service_id       String
  user_id          String?  // Null = signalement anonyme (sans connexion)
  correction_type  String   // "wrong_address" | "wrong_phone" | "closed" | "wrong_hours" | "other"
  description      String   @db.Text
  status           String   @default("pending") // "pending" | "reviewed" | "applied" | "rejected"
  reviewed_by      String?  // UUID de l'admin
  reviewed_at      DateTime?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  service          PublicService @relation(fields: [service_id], references: [id])
  user             User?         @relation(fields: [user_id], references: [id])

  @@index([service_id, status])
  @@index([status, created_at]) // Pour la liste des signalements en attente (admin)
  @@map("service_corrections")
}

// =============================================================
// SECTION 12 — ÉVÉNEMENTS & BILLETS
// 4 tables : event_categories, events, event_ticket_types, event_bookings
//
// Flux de vie d'un événement :
//   Organisateur soumet → status "pending_approval"
//   Admin vérifie → "approved" ou "rejected"
//   Organisateur paie les frais de publication → has_paid_publishing = true
//   Billetterie ouverte → utilisateurs réservent des EventBooking
//   Après validation de chaque billet à l'entrée → status "checked_in"
//
// Revenue VIVRE :
//   - Frais de publication : publishing_fee_fcfa (défaut 5 000 FCFA, négociable)
//   - Commission sur ventes : commission_percent (défaut 5%, négociable)
// =============================================================

// Catégories d'événements (concert, sport, festival, conférence…)
model EventCategory {
  id        String  @id @default(uuid())
  name      String  @unique // "Concert", "Festival", "Sport", "Conférence", "Culturel", "Religieux"
  name_en   String?
  icon      String?          // Emoji ou nom d'icône Lucide
  color_hex String  @default("#1A6B3A")
  is_active Boolean @default(true)

  events    Event[]

  @@map("event_categories")
}

// Événement organisé sur la plateforme VIVRE.
// L'organisateur est un User avec rôle supplier (supplier_type = "events").
// Après approbation admin, les tickets peuvent être vendus.
model Event {
  id          String   @id @default(uuid())
  organizer_id String  // User (rôle supplier) qui organise l'événement
  city_id      String
  category_id  String

  title        String
  slug         String  @unique // URL-friendly, ex: "faso-fest-2026-ouagadougou"
  description  String  @db.Text // Description complète (Markdown supporté côté client)
  cover_url    String?           // Image de couverture principale
  gallery_urls String[]          // Photos supplémentaires (max 10 recommandé)

  // Localisation du lieu
  venue_name    String  // Nom du lieu, ex: "Stade du 4 Août"
  venue_address String  // Adresse complète
  latitude      Float?
  longitude     Float?

  // Temporalité
  starts_at DateTime
  ends_at   DateTime

  // Capacité maximale autorisée
  max_capacity Int

  // Informations de sécurité — transmises à la police si demandé
  // L'organisateur doit décrire : plan de sécurité, sorties de secours,
  // personnel de sécurité prévu, restrictions d'âge, etc.
  safety_description String?  @db.Text
  expected_profile   String?  // Description du public attendu (familles, adultes, etc.)

  // Statut — cycle de vie
  status           String @default("draft")
  // "draft"            : brouillon (organisateur en cours de rédaction)
  // "pending_approval" : soumis à l'admin pour validation
  // "approved"         : validé — tickets en vente si has_paid_publishing = true
  // "rejected"         : rejeté avec raison
  // "cancelled"        : annulé après publication
  // "completed"        : événement terminé
  rejection_reason String?    // Si rejected : explication pour l'organisateur
  is_featured      Boolean @default(false) // Mis en avant par l'admin sur la home

  // Politique de remboursement — configurée par l'organisateur
  refund_enabled      Boolean @default(false) // true = l'organisateur autorise les remboursements
  refund_cutoff_hours Int?    // Heures avant l'événement jusqu'auxquelles on peut annuler

  // Revenue VIVRE — valeurs par défaut, modifiables par l'admin par accord commercial
  publishing_fee_fcfa Int   @default(5000)  // Frais fixes de publication
  commission_percent  Float @default(5.0)   // % commission sur chaque vente de ticket
  has_paid_publishing Boolean @default(false) // true = frais de publication réglés

  // Avis clients agrégés
  rating_avg    Float @default(0)

  // Rapport police
  // L'admin peut marquer l'événement comme notifié aux autorités
  police_notified_at DateTime? // null = pas encore notifié aux forces de l'ordre

  // Métadonnées d'approbation
  approved_by String?   // UUID de l'admin qui a approuvé
  approved_at DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?

  organizer    User            @relation("OrganizedEvents", fields: [organizer_id], references: [id])
  city         City            @relation(fields: [city_id], references: [id])
  category     EventCategory   @relation(fields: [category_id], references: [id])
  ticket_types EventTicketType[]
  bookings     EventBooking[]

  @@index([city_id, status, starts_at])        // Découverte par ville
  @@index([organizer_id, status])              // Dashboard organisateur
  @@index([status, starts_at])                 // Événements approuvés futurs (home)
  @@index([slug])                              // Lookup par slug (page événement)
  @@map("events")
}

// Type de billet pour un événement — un événement peut avoir plusieurs types.
// Ex: "VIP" (25 000 FCFA, 50 places), "Standard" (5 000 FCFA, 500 places)
model EventTicketType {
  id          String @id @default(uuid())
  event_id    String

  name        String  // "VIP", "Standard", "Early Bird", "Gratuit"
  description String? // Ce qui est inclus (ex: "Accès backstage + cocktail dînatoire")
  price_fcfa  Int     // 0 = billet gratuit (inscription requise quand même)
  quantity    Int     // Nombre total de billets disponibles pour ce type
  max_per_order Int @default(10) // Limite anti-scalping par réservation

  // Période de vente — null = pas de restriction de date
  sale_starts_at DateTime?
  sale_ends_at   DateTime?

  is_active Boolean @default(true)

  event    Event          @relation(fields: [event_id], references: [id])
  bookings EventBooking[]

  @@index([event_id, is_active])
  @@map("event_ticket_types")
}

// Réservation de billet(s) par un utilisateur.
// Un EventBooking = une commande (potentiellement plusieurs billets du même type).
// Le QR code est unique par booking et scanné une seule fois à l'entrée.
model EventBooking {
  id             String @id @default(uuid())
  user_id        String
  event_id       String
  ticket_type_id String

  quantity        Int
  unit_price_fcfa Int  // Snapshot du prix unitaire au moment de la réservation
  total_amount    Int  // FCFA = quantity × unit_price_fcfa
  commission_fcfa Int  // Part VIVRE (commission_percent × total_amount / 100)

  status String @default("pending")
  // "pending"    : en attente de paiement (billet réservé 10 min)
  // "confirmed"  : paiement validé, billet émis
  // "cancelled"  : annulé par l'utilisateur ou l'organisateur
  // "checked_in" : scanné et validé à l'entrée de l'événement

  qr_code String // Données encodées en base64 pour le QR code de validation

  payment_id  String?
  checked_in_at DateTime? // Timestamp du scan à l'entrée
  cancelled_at  DateTime?
  cancellation_reason String?

  // Transfert de billet — le propriétaire cède son billet à un autre utilisateur
  transferred_to_id String?   // UUID de l'utilisateur destinataire
  transferred_at    DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user            User            @relation("EventBookingOwner", fields: [user_id], references: [id])
  transferred_to  User?           @relation("EventBookingTransfer", fields: [transferred_to_id], references: [id])
  event           Event           @relation(fields: [event_id], references: [id])
  ticket_type     EventTicketType @relation(fields: [ticket_type_id], references: [id])
  payment         Payment?        @relation(fields: [payment_id], references: [id])

  @@index([event_id, status])
  @@index([user_id, status])
  @@map("event_bookings")
}

// =============================================================
// SECTION 12 — PORTEFEUILLE VIVRE
// Crédits accumulés par remboursements, utilisables sur toutes les réservations.
// =============================================================

// Solde de crédit VIVRE par utilisateur.
// Crédité lors d'un remboursement en "vivre_credit".
// Débité lors d'un paiement partiel ou total avec le portefeuille.
model VivreWallet {
  id           String   @id @default(uuid())
  user_id      String   @unique
  balance_fcfa Int      @default(0) // Solde disponible en FCFA
  updated_at   DateTime @updatedAt

  user         User              @relation(fields: [user_id], references: [id])
  transactions WalletTransaction[]

  @@map("vivre_wallets")
}

// Journal des mouvements du portefeuille.
// amount_fcfa positif = crédit, négatif = débit.
model WalletTransaction {
  id           String   @id @default(uuid())
  wallet_id    String
  amount_fcfa  Int      // +crédit ou -débit
  type         String   // "refund" | "booking_payment" | "admin_credit"
  reference_id String?  // ID du Refund ou de la réservation associée
  description  String   // Texte lisible (ex: "Remboursement annulation hôtel Le Relais")
  created_at   DateTime @default(now())

  wallet       VivreWallet @relation(fields: [wallet_id], references: [id])

  @@index([wallet_id, created_at])
  @@map("wallet_transactions")
}
