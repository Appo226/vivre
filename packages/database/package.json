{
  "name": "@vivre/database",
  "version": "0.1.0",
  "private": true,
  "description": "Prisma ORM et schéma de base de données pour VIVRE",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "require": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "migrate:prod": "prisma migrate deploy",
    "seed": "tsx src/seed.ts",
    "studio": "prisma studio",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf node_modules/.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0"
  },
  "devDependencies": {
    "@vivre/config": "workspace:*",
    "@vivre/utils": "workspace:*",
    "prisma": "^5.14.0",
    "rimraf": "^5.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "prisma": {
    "seed": "tsx src/seed.ts"
  }
}
