{
  /**
   * @vivre/utils — Utilitaires partagés pour le monorepo VIVRE
   *
   * Contient les fonctions utilitaires qui n'ont pas de logique métier
   * mais qui sont utilisées dans plusieurs apps :
   * - currency.ts  : Formatage des montants FCFA
   * - date.ts      : Manipulation des dates (dayjs + timezone Africa/Ouagadougou)
   * - geo.ts       : Calculs géographiques (distance, coordonnées)
   * - validation.ts: Schémas Zod réutilisables (téléphone BF, coordonnées GPS)
   * - phone.ts     : Normalisation des numéros burkinabè (+226)
   */
  "name": "@vivre/utils",
  "version": "0.1.0",
  "private": true,
  "description": "Utilitaires partagés pour le monorepo VIVRE",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "dayjs": "^1.11.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@vivre/config": "workspace:*",
    "@vivre/types": "workspace:*",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0"
  }
}
