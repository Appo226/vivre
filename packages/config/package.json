{
  /**
   * @vivre/config — Package de configuration partagée
   *
   * Pourquoi centraliser la config ?
   * Sans ce package, chaque app aurait son propre tsconfig, eslintrc, tailwind.config.
   * Un changement de règle ESLint demanderait de modifier 4 fichiers. Avec ce package,
   * un seul endroit à modifier, propagé à toutes les apps automatiquement.
   *
   * Ce package contient :
   * - tsconfig/base.json       : TypeScript strict pour tous les packages Node
   * - tsconfig/nextjs.json     : Extension pour les apps Next.js (JSX, bundler)
   * - tsconfig/fastify.json    : Extension pour l'API Fastify
   * - eslint/index.js          : Règles ESLint partagées
   * - tailwind/index.ts        : Configuration Tailwind avec le design system VIVRE
   */
  "name": "@vivre/config",
  "version": "0.1.0",
  "private": true,
  "description": "Configuration partagée ESLint, TypeScript, Tailwind pour le monorepo VIVRE",
  "main": "./eslint/index.js",
  "exports": {
    "./eslint": "./eslint/index.js",
    "./tailwind": "./tailwind/index.ts",
    "./tsconfig/base": "./tsconfig/base.json",
    "./tsconfig/nextjs": "./tsconfig/nextjs.json",
    "./tsconfig/fastify": "./tsconfig/fastify.json"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0"
  }
}
