{
  /**
   * @vivre/ui — Design system partagé pour VIVRE
   *
   * Composants React réutilisables par apps/web, apps/admin et apps/supplier.
   * Construit sur Radix UI (accessibilité) + Tailwind CSS (design system VIVRE).
   *
   * Composants inclus dans le scaffold :
   * - Button : avec variants (primary, secondary, danger, ghost) et loading state
   * - Badge  : pour les statuts (Confirmé, Annulé, De garde, etc.)
   * - Skeleton : états de chargement pour les listes et cards
   * - Input : champ texte avec gestion d'erreurs Zod
   * - Card : conteneur standard pour les résultats de recherche
   *
   * NB: Ce package est "server-component safe" — pas de hooks ni de contextes.
   * Les composants avec state (modales, dropdowns) sont dans apps/web/src/components/.
   */
  "name": "@vivre/ui",
  "version": "0.1.0",
  "private": true,
  "description": "Design system et composants partagés pour le monorepo VIVRE",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.367.0",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@vivre/config": "workspace:*",
    "@vivre/types": "workspace:*",
    "@types/react": "^18.3.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0"
  }
}
