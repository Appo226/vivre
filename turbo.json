{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**",
        "build/**"
      ],
      "env": [
        "DATABASE_URL",
        "REDIS_URL",
        "JWT_SECRET",
        "ANTHROPIC_API_KEY",
        "NEXT_PUBLIC_API_URL",
        "NEXT_PUBLIC_WS_URL",
        "NEXT_PUBLIC_MAPLIBRE_STYLE",
        "NEXT_PUBLIC_DEFAULT_CITY",
        "NEXT_PUBLIC_DEFAULT_LAT",
        "NEXT_PUBLIC_DEFAULT_LNG"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": [],
      "env": ["DATABASE_URL", "REDIS_URL", "JWT_SECRET"]
    },
    "clean": {
      "cache": false
    }
  }
}
