# =============================================================
# VIVRE Platform — Fichier d'exemple de variables d'environnement
#
# INSTRUCTIONS :
#   cp .env.example .env.local
#   Puis remplir chaque valeur avant de lancer `pnpm dev`
#
# SÉCURITÉ :
#   .env.local est dans .gitignore — ne jamais committer les vraies valeurs
#   Les secrets de production sont injectés via CI/CD (GitHub Actions Secrets)
# =============================================================

# -------------------------------------------------------------
# BASE DE DONNÉES
# PostgreSQL avec extension PostGIS (requis pour les requêtes géographiques)
# PostGIS permet de calculer les distances GPS pour trier les services publics
# -------------------------------------------------------------
DATABASE_URL="postgresql://vivre_user:vivre_pass@localhost:5432/vivre_dev?schema=public"

# -------------------------------------------------------------
# CACHE / SESSIONS TEMPS RÉEL
# Redis stocke : sessions JWT, cache API (24h), données de positions drivers (3s TTL)
# -------------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# -------------------------------------------------------------
# SERVEUR API FASTIFY
# -------------------------------------------------------------
API_PORT=3001
NODE_ENV=development

# JWT — Doit être une chaîne aléatoire de minimum 64 caractères
# Générer avec : openssl rand -base64 64
JWT_SECRET="CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# CORS — En développement, autoriser toutes les origines locales
CORS_ORIGIN="http://localhost:3000,http://localhost:3002,http://localhost:3003"

# -------------------------------------------------------------
# ANTHROPIC CLAUDE AI — Moteur de l'assistant IA VIVRE
# L'assistant répond en français, contextualisé pour le Burkina Faso
# Utilise Claude pour comprendre "Où dormir pas cher à Bobo ?" → cherche hôtels
# -------------------------------------------------------------
ANTHROPIC_API_KEY="sk-ant-CHANGE_ME"
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# -------------------------------------------------------------
# PINECONE — Base de données vectorielle pour le RAG (Retrieval-Augmented Generation)
# Stocke les embeddings des hôtels, restaurants, attractions pour l'IA contextuelle
# -------------------------------------------------------------
PINECONE_API_KEY="CHANGE_ME"
PINECONE_INDEX="vivre-rag"

# -------------------------------------------------------------
# PAIEMENTS MOBILES — Mobile Money Burkina Faso
# Orange Money et Moov Money = 90%+ des transactions numériques au Burkina
# -------------------------------------------------------------
ORANGE_MONEY_API_KEY="CHANGE_ME"
ORANGE_MONEY_MERCHANT_ID="CHANGE_ME"
ORANGE_MONEY_WEBHOOK_SECRET="CHANGE_ME"
ORANGE_MONEY_BASE_URL="https://api.orange.com/orange-money-webpay/bf/v1"

MOOV_MONEY_API_KEY="CHANGE_ME"
MOOV_MONEY_MERCHANT_ID="CHANGE_ME"
MOOV_MONEY_WEBHOOK_SECRET="CHANGE_ME"

# -------------------------------------------------------------
# STRIPE — Paiement par carte bancaire (touristes internationaux)
# -------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_CHANGE_ME"
STRIPE_WEBHOOK_SECRET="whsec_CHANGE_ME"

# -------------------------------------------------------------
# COMMISSION PLATEFORME — Pourcentage prélevé sur chaque transaction
# -------------------------------------------------------------
PLATFORM_COMMISSION_PERCENT=12

# -------------------------------------------------------------
# TWILIO — SMS pour les OTP de connexion (téléphones +226 Burkina)
# WhatsApp Business pour l'envoi de tickets et confirmations
# -------------------------------------------------------------
TWILIO_ACCOUNT_SID="CHANGE_ME"
TWILIO_AUTH_TOKEN="CHANGE_ME"
TWILIO_PHONE_NUMBER="+12345678901"

WHATSAPP_BUSINESS_TOKEN="CHANGE_ME"
WHATSAPP_PHONE_NUMBER_ID="CHANGE_ME"
WHATSAPP_VERIFY_TOKEN="CHANGE_ME"

# -------------------------------------------------------------
# AWS S3 — Stockage des médias (photos hôtels, menus, avatars)
# Région af-south-1 (Afrique du Sud) pour la latence Burkina
# -------------------------------------------------------------
AWS_ACCESS_KEY_ID="CHANGE_ME"
AWS_SECRET_ACCESS_KEY="CHANGE_ME"
AWS_REGION="af-south-1"
AWS_S3_BUCKET="vivre-media-prod"

# -------------------------------------------------------------
# FIREBASE — Push Notifications mobile (PWA)
# Envoi des notifications en temps réel aux chauffeurs et clients
# -------------------------------------------------------------
FIREBASE_PROJECT_ID="CHANGE_ME"
FIREBASE_PRIVATE_KEY="CHANGE_ME"
FIREBASE_CLIENT_EMAIL="CHANGE_ME"

# -------------------------------------------------------------
# VARIABLES PUBLIQUES NEXT.JS (exposées au navigateur — pas de secrets ici !)
# Préfixées NEXT_PUBLIC_ pour être incluses dans le bundle client
# -------------------------------------------------------------
NEXT_PUBLIC_API_URL="http://localhost:3001/v1"
NEXT_PUBLIC_WS_URL="http://localhost:3001"

# Style de carte MapLibre (tuiles vectorielles open-source)
# OpenFreeMap est gratuit pour les projets non-commerciaux
NEXT_PUBLIC_MAPLIBRE_STYLE="https://tiles.openfreemap.org/styles/liberty"

# UUID de la ville de Ouagadougou (généré lors du seed de la base)
# Sera mis à jour après le premier `pnpm db:seed`
NEXT_PUBLIC_DEFAULT_CITY="WILL_BE_SET_AFTER_SEED"

# Coordonnées GPS de Ouagadougou (centre-ville)
NEXT_PUBLIC_DEFAULT_LAT=12.3647
NEXT_PUBLIC_DEFAULT_LNG=-1.5338
